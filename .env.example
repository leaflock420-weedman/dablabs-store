# PayPal REST API — copy to .env and fill in from developer.paypal.com
# Apps & Credentials → Create App → Sandbox (test first) then Live

# sandbox | live
PAYPAL_MODE=sandbox

# Sandbox credentials (test payments)
PAYPAL_SANDBOX_CLIENT_ID=your_sandbox_client_id
PAYPAL_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret

# Live credentials (real payments — only after testing)
PAYPAL_LIVE_CLIENT_ID=your_live_client_id
PAYPAL_LIVE_CLIENT_SECRET=your_live_client_secret

# Webhook ID from PayPal Developer → your app → Webhooks (after adding webhook URL)
# Webhook URL to register in PayPal dashboard:
#   Local dev (ngrok): https://YOUR-NGROK-ID.ngrok.io/api/paypal/webhook
#   Production:        https://dablabs.com.au/api/paypal/webhook
PAYPAL_WEBHOOK_ID=

# Server
PORT=3000
STORE_EMAIL=hello@dablabs.com.au

# Order email alerts (Gmail example — use an App Password, not your normal password)
ORDER_NOTIFY_EMAIL=hello@dablabs.com.au
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Dab Labs Store <your@gmail.com>"
SEND_CUSTOMER_RECEIPT=true

# Orders admin page: https://yoursite.onrender.com/admin/orders?key=YOUR_SECRET
ADMIN_ORDERS_SECRET=change_me_to_a_long_random_string